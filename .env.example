# Neon Postgres connection string (serverless / neon-http driver)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Cloudflare R2 (S3-compatible) storage
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="your-r2-bucket-name"
# Public base URL for the R2 bucket (custom domain or *.r2.dev). Not a secret —
# its hostname is added to next.config.mjs images.remotePatterns.
R2_PUBLIC_BASE_URL="https://cdn.example.com"

# Admin portal auth
ADMIN_PASSWORD="your-plaintext-admin-password"   # plaintext; compared constant-time on login
SESSION_SECRET="a-long-random-string"            # HMAC signing secret for the session cookie
